
{
  "manifest_version": 3,
  "name": "Sci-Share Scanner",
  "version": "1.0.0",
  "description": "Scan scientific assets for data integrity and duplicates.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"]
}
