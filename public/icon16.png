x, 0px); content-visibility: visible;"><defs><clippath id="__lottie_element_353"><rect width="32" height="32" x="0" y="0"></rect></clippath><lineargradient id="__lottie_element_357" spreadMethod="pad" gradientUnits="userSpaceOnUse"><stop></stop><stop></stop><stop></stop><stop></stop><stop></stop></lineargradient><lineargradient id="__lottie_element_364" spreadMethod="pad" gradientUnits="userSpaceOnUse"><stop></stop><stop></stop><stop></stop></lineargradient><lineargradient id="__lottie_element_368" spreadMethod="pad" gradientUnits="userSpaceOnUse"><stop></stop><stop></stop><stop></stop></lineargradient><lineargradient id="__lottie_element_372" spreadMethod="pad" gradientUnits="userSpaceOnUse"><stop></stop><stop></stop><stop></stop></lineargradient><lineargradient id="__lottie_element_376" spreadMethod="pad" gradientUnits="userSpaceOnUse"><stop></stop><stop></stop><stop></stop><stop></stop><stop></stop></lineargradient><lineargradient id="__lottie_element_380" spreadMethod="pad" gradientUnits="userSpaceOnUse" x1="-16" y1="0" x2="16" y2="0"><stop offset="0%" stop-color="rgb(49,134,255)"></stop><stop offset="50%" stop-color="rgb(49,134,255)"></stop><stop offset="100%" stop-color="rgb(49,134,255)"></stop><stop offset="100%" stop-color="rgb(49,134,255)"></stop><stop offset="100%" stop-color="rgb(49,134,255)"></stop></lineargradient></defs><g clip-path="url(#__lottie_element_353)"><g style="display: block;" transform="matrix(1,0,0,1,16,16)" opacity="1"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_380)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M-4.383999824523926,-14.347999572753906 C-2.996999979019165,-14.772000312805176 -1.524999976158142,-15 0,-15 C0,-15 0,-15 0,-15 C1.7100000381469727,-15 3.3540000915527344,-14.713000297546387 4.886000156402588,-14.1850004196167"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_376)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_372)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_368)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_364)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_357)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g></g></svg></div></div></bard-avatar><!----><!----></div><!----><div _ngcontent-ng-c1883881203="" class="response-container-content ng-tns-c1883881203-21"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c3748022998="" class="response-content ng-tns-c1883881203-21"><!----><div _ngcontent-ng-c3748022998="" class="thoughts-container ng-star-inserted"><!----></div><!----><!----><!----><!----><!----><h2 _ngcontent-ng-c3748022998="" class="cdk-visually-hidden ng-star-inserted">Gemini a dit</h2><!----><!----><structured-content-container _ngcontent-ng-c3748022998="" class="model-response-text processing-state-visible ng-star-inserted" _nghost-ng-c4085131935="" style="height: auto;"><div _ngcontent-ng-c4085131935="" class="container"><message-content _ngcontent-ng-c4085131935="" _nghost-ng-c3807329646="" id="message-content-id-r_26a01bd788c0cddf" class="ng-star-inserted"><div _ngcontent-ng-c3807329646="" inline-copy-host="" class="markdown markdown-main-panel stronger enable-updated-hr-color" style="--animation-duration: 400ms; --fade-animation-function: linear;" id="model-response-message-contentr_26a01bd788c0cddf" aria-live="off" aria-busy="false" dir="ltr"><p data-path-to-node="0">Building a 1-click image integrity scanner similar to <b data-path-to-node="0" data-index-in-node="54">FigCheck</b> or <b data-path-to-node="0" data-index-in-node="66">Proofig</b> is a high-level project because those tools use complex AI to detect "splices" or "clones" in pixels.</p><p data-path-to-node="1">However, in 2026, you can achieve this <b data-path-to-node="1" data-index-in-node="39">without writing code</b> by using an <b data-path-to-node="1" data-index-in-node="72">AI Extension Builder</b> and connecting it to a pre-built image forensic service.</p><hr data-path-to-node="2"><h2 data-path-to-node="3">🛠️ The Architecture</h2><p data-path-to-node="4">To do this for free and without coding, you will use a "No-Code" sandwich:</p><ol start="1" data-path-to-node="5"><li><p data-path-to-node="5,0,0"><b data-path-to-node="5,0,0" data-index-in-node="0">The Interface:</b> An AI tool that builds the Chrome button for you.</p></li><li><p data-path-to-node="5,1,0"><b data-path-to-node="5,1,0" data-index-in-node="0">The Brain:</b> A free forensic API or web service (like <i data-path-to-node="5,1,0" data-index-in-node="52">Forensically</i> or <i data-path-to-node="5,1,0" data-index-in-node="68">FotoForensics</i>) that does the actual scanning.</p></li></ol><hr data-path-to-node="6"><h2 data-path-to-node="7">🚀 Step-by-Step Guide</h2><h3 data-path-to-node="8">Step 1: Choose Your No-Code Builder</h3><p data-path-to-node="9">The easiest tool in 2026 is <b data-path-to-node="9" data-index-in-node="28">Kromio.ai</b> or <b data-path-to-node="9" data-index-in-node="41">Manus.im</b>. These are "Vibe Coding" platforms where you describe the app, and they generate the files.</p><h3 data-path-to-node="10">Step 2: The "1-Click" Prompt</h3><p data-path-to-node="11">Go to your chosen builder and paste this specific prompt. This tells the AI exactly how to behave like Proofig:</p><blockquote data-path-to-node="12"><p data-path-to-node="12,0">"Create a Chrome Extension that adds a right-click menu option called 'Scan Image Integrity'. When clicked on an image, it should capture the image URL and send it to the <response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><link-block _nghost-ng-c1796846746="" class="ng-star-inserted"><!----><!----><a _ngcontent-ng-c1796846746="" target="_blank" rel="noopener" externallink="" _nghost-ng-c412475248="" jslog="197247;track:generic_click,impression,attention;BardVeMetadataKey:[[&quot;r_26a01bd788c0cddf&quot;,&quot;c_900130c3d9008f9e&quot;,null,&quot;rc_a864434524ef640b&quot;,null,null,&quot;en&quot;,null,1,null,null,1,0]]" href="https://29a.ch/photo-forensics/" class="ng-star-inserted" data-hveid="0" decode-data-ved="1" data-ved="0CAAQ_4QMahcKEwihq_2QlpqTAxUAAAAAHQAAAAAQOw">Forensically</a><!----></link-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element> web tool for Error Level Analysis (ELA). The extension should open the analysis in a new side-panel or tab."</p></blockquote><h3 data-path-to-node="13">Step 3: Configure the Logic (The "Brain")</h3><p data-path-to-node="14">Since you aren't coding the AI yourself, your extension will "hand off" the image to a forensic engine.</p><ul data-path-to-node="15"><li><p data-path-to-node="15,0,0"><b data-path-to-node="15,0,0" data-index-in-node="0">For Duplication/Manipulation:</b> Use the <b data-path-to-node="15,0,0" data-index-in-node="38">Forensically βeta</b> URL structure.</p></li><li><p data-path-to-node="15,1,0"><b data-path-to-node="15,1,0" data-index-in-node="0">For Metadata/Source:</b> Use <b data-path-to-node="15,1,0" data-index-in-node="25">Jeffrey's Image Metadata Viewer</b>.</p></li></ul><h3 data-path-to-node="16">Step 4: Installation (Developer Mode)</h3><p data-path-to-node="17">Once the AI builder gives you a <code data-path-to-node="17" data-index-in-node="32">.zip</code> file:</p><ol start="1" data-path-to-node="18"><li><p data-path-to-node="18,0,0"><b data-path-to-node="18,0,0" data-index-in-node="0">Unzip</b> the folder to your desktop.</p></li><li><p data-path-to-node="18,1,0">Open Chrome and type <code data-path-to-node="18,1,0" data-index-in-node="21">chrome://extensions/</code> in the address bar.</p></li><li><p data-path-to-node="18,2,0">Toggle <b data-path-to-node="18,2,0" data-index-in-node="7">Developer Mode</b> (top right) to <b data-path-to-node="18,2,0" data-index-in-node="37">ON</b>.</p></li><li><p data-path-to-node="18,3,0">Click <b data-path-to-node="18,3,0" data-index-in-node="6">Load unpacked</b> and select your unzipped folder.</p></li></ol><hr data-path-to-node="19"><h2 data-path-to-node="20">🔍 How it Works (Visualized)</h2><div class="horizontal-scroll-wrapper"><div class="table-block-component"><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><table-block _nghost-ng-c2976694548="" class="ng-star-inserted"><div _ngcontent-ng-c2976694548="" class="table-block has-export-button new-table-style is-at-scroll-start is-at-scroll-end"><div _ngcontent-ng-c2976694548="" not-end-of-paragraph="" class="table-content not-end-of-paragraph" jslog="275421;track:impression,attention" data-hveid="0" decode-data-ved="1" data-ved="0CAAQ3ecQahcKEwihq_2QlpqTAxUAAAAAHQAAAAAQPA"><table data-path-to-node="21"><thead><tr><td><span data-path-to-node="21,0,0,0">Feature</span></td><td><span data-path-to-node="21,0,1,0">Your No-Code Extension</span></td><td><span data-path-to-node="21,0,2,0">Proofig / ImageTwin</span></td></tr></thead><tbody><tr><td><span data-path-to-node="21,1,0,0"><b data-path-to-node="21,1,0,0" data-index-in-node="0">Access</b></span></td><td><span data-path-to-node="21,1,1,0">1-Click Right Click</span></td><td><span data-path-to-node="21,1,2,0">Manual Upload</span></td></tr><tr><td><span data-path-to-node="21,2,0,0"><b data-path-to-node="21,2,0,0" data-index-in-node="0">Detection</b></span></td><td><span data-path-to-node="21,2,1,0">Error Level Analysis (ELA)</span></td><td><span data-path-to-node="21,2,2,0">Deep Learning AI</span></td></tr><tr><td><span data-path-to-node="21,3,0,0"><b data-path-to-node="21,3,0,0" data-index-in-node="0">Database</b></span></td><td><span data-path-to-node="21,3,1,0">Public Web Search</span></td><td><span data-path-to-node="21,3,2,0">Private Journal Database</span></td></tr><tr><td><span data-path-to-node="21,4,0,0"><b data-path-to-node="21,4,0,0" data-index-in-node="0">Cost</b></span></td><td><span data-path-to-node="21,4,1,0"><b data-path-to-node="21,4,1,0" data-index-in-node="0">$0 (Free)</b></span></td><td><span data-path-to-node="21,4,2,0">High Subscription Fees</span></td></tr></tbody></table></div><div _ngcontent-ng-c2976694548="" hide-from-message-actions="" class="table-footer hide-from-message-actions"><button _ngcontent-ng-c2976694548="" mat-button="" class="mdc-button mat-mdc-button-base export-sheets-button-container mat-mdc-button mat-unthemed ng-star-inserted" mat-ripple-loader-class-name="mat-mdc-button-ripple" jslog="184701;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_26a01bd788c0cddf&quot;,&quot;c_900130c3d9008f9e&quot;,null,null,null,null,null,null,1,null,null,null,0]]"><span class="mat-mdc-button-persistent-ripple mdc-button__ripple"></span><span class="mdc-button__label"><span _ngcontent-ng-c2976694548="" class="export-sheets-button"><span _ngcontent-ng-c2976694548="" class="export-sheets-icon"><mat-icon _ngcontent-ng-c2976694548="" role="img" fonticon="drive_spreadsheet" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="drive_spreadsheet"></mat-icon></span><span _ngcontent-ng-c2976694548="">Exporter vers Sheets</span></span></span><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span><span class="mat-ripple mat-mdc-button-ripple"></span></button><!----><button _ngcontent-ng-c2976694548="" mat-icon-button="" mattooltip="Copier le tableau" aria-label="Copier le tableau" data-test-id="copy-table-button" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="276666;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_26a01bd788c0cddf&quot;,&quot;c_900130c3d9008f9e&quot;,null,null,null,null,null,null,1,null,null,null,0]]"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c2976694548="" role="img" fonticon="content_copy" class="mat-icon notranslate gds-icon-l google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----></div></div><!----></table-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element></div></div><hr data-path-to-node="22"><h2 data-path-to-node="23">⚠️ Important Limitations</h2><ul data-path-to-node="24"><li><p data-path-to-node="24,0,0"><b data-path-to-node="24,0,0" data-index-in-node="0">Privacy:</b> Since you are using a free version, avoid scanning sensitive or unpublished data. Most free forensic tools are "Public," meaning your image might be indexed.</p></li><li><p data-path-to-node="24,1,0"><b data-path-to-node="24,1,0" data-index-in-node="0">Accuracy:</b> Unlike Proofig (which costs thousands), a no-code tool relies on visual filters (like ELA) rather than a comparative database of 50 million papers. It will help you see if an image was <b data-path-to-node="24,1,0" data-index-in-node="195">Photoshopped</b>, but it won't tell you if it was <b data-path-to-node="24,1,0" data-index-in-node="241">stolen</b> from another paper.</p></li></ul><hr data-path-to-node="25"><p data-path-to-node="26"><b data-path-to-node="26" data-index-in-node="0">Would you like me to generate the specific "Manifest V3" code block for you so you can manually create the files if the AI builder fails?</b></p></div></message-content><!----></div></structured-content-container><!----><!----><div _ngcontent-ng-c3748022998="" class="response-footer gap complete"><!----><!----><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c3748022998="" role="status" class="stopped-draft-message gds-body-l gds-italic ng-star-inserted" hidden="" wfd-invisible="true">Vous avez interrompu cette réponse</div><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c3748022998="" _nghost-ng-c3363139195="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c1883881203="" class="response-container-footer ng-tns-c1883