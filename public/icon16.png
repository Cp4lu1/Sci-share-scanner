0000047683716,-86.73999786376953 1.850000023841858,-88 0,-88 C-1.850000023841858,-88 -3.450000047683716,-86.73999786376953 -3.9000000953674316,-84.94999694824219z"></path></g></g></g><path d=" M84.8499984741211,3.799999952316284 C83.47000122070312,9.279999732971191 81.66999816894531,14.609999656677246 79.43000030517578,19.81999969482422 C73.58999633789062,33.380001068115234 65.58999633789062,45.25 55.41999816894531,55.41999816894531 C45.25,65.58000183105469 33.380001068115234,73.58999633789062 19.81999969482422,79.43000030517578 C14.619999885559082,81.66999816894531 9.279999732971191,83.47000122070312 3.799999952316284,84.8499984741211 C2.009999990463257,85.30000305175781 0.75,86.9000015258789 0.75,88.75 C0.75,90.5999984741211 2.009999990463257,92.19999694824219 3.799999952316284,92.6500015258789 C9.279999732971191,94.02999877929688 14.609999656677246,95.83000183105469 19.81999969482422,98.06999969482422 C33.380001068115234,103.91000366210938 45.2400016784668,111.91000366210938 55.41999816894531,122.08000183105469 C65.58999633789062,132.25 73.5999984741211,144.1199951171875 79.43000030517578,157.67999267578125 C81.66999816894531,162.8800048828125 83.47000122070312,168.22000122070312 84.8499984741211,173.6999969482422 C85.30000305175781,175.49000549316406 86.91000366210938,176.75 88.75,176.75 C90.5999984741211,176.75 92.19999694824219,175.49000549316406 92.6500015258789,173.6999969482422 C94.02999877929688,168.22000122070312 95.83000183105469,162.88999938964844 98.06999969482422,157.67999267578125 C103.91000366210938,144.1199951171875 111.91000366210938,132.25999450683594 122.08000183105469,122.08000183105469 C132.25,111.91000366210938 144.1199951171875,103.9000015258789 157.67999267578125,98.06999969482422 C162.8800048828125,95.83000183105469 168.22000122070312,94.02999877929688 173.6999969482422,92.6500015258789 C175.49000549316406,92.19999694824219 176.75,90.58999633789062 176.75,88.75 C176.75,86.9000015258789 175.49000549316406,85.30000305175781 173.6999969482422