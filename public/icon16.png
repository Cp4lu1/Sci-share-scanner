set="100%" stop-color="rgb(49,134,255)"></stop><stop offset="100%" stop-color="rgb(49,134,255)"></stop></lineargradient></defs><g clip-path="url(#__lottie_element_1249)"><g style="display: block;" transform="matrix(1,0,0,1,16,16)" opacity="1"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_1276)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M-4.383999824523926,-14.347999572753906 C-2.996999979019165,-14.772000312805176 -1.524999976158142,-15 0,-15 C0,-15 0,-15 0,-15 C1.7100000381469727,-15 3.3540000915527344,-14.713000297546387 4.886000156402588,-14.1850004196167"></path></g></g><g style="display: none;" transform="matrix(1,0,0,1,16,16)" opacity="1" wfd-invisible="true"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_1272)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M10.314000129699707,10.88700008392334 C7.625,13.435999870300293 3.99399995803833,15 0,15 C-7.660999774932861,15 -13.98900032043457,9.244000434875488 -14.890000343322754,1.8240000009536743"></path></g></g><g style="display: none;" transform="matrix(1,0,0,1,16,16)" opacity="1" wfd-invisible="true"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_1268)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M-4.492000102996826,-14.3149995803833 C-3.0739998817443848,-14.760000228881836 -1.565000057220459,-15 0,-15 C0,-15 0,-15 0,-15 C1.6710000038146973,-15 3.2780001163482666,-14.72599983215332 4.7789998054504395,-14.220999717712402"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_1264)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_1260)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_1253)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g></g></svg></div></div></bard-avatar><!----><!----></div><!----><div _ngcontent-ng-c1883881203="" class="response-container-content ng-tns-c1883881203-56"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c3748022998="" class="response-content ng-tns-c1883881203-56"><!----><div _ngcontent-ng-c3748022998="" class="thoughts-container ng-star-inserted"><!----></div><!----><!----><!----><!----><!----><h2 _ngcontent-ng-c3748022998="" class="cdk-visually-hidden ng-star-inserted">Gemini a dit</h2><!----><!----><structured-content-container _ngcontent-ng-c3748022998="" class="model-response-text processing-state-visible ng-star-inserted" _nghost-ng-c4085131935="" style="height: auto;"><div _ngcontent-ng-c4085131935="" class="container"><message-content _ngcontent-ng-c4085131935="" _nghost-ng-c3807329646="" id="message-content-id-r_f87aebfb0f8c8e83" class="ng-star-inserted"><div _ngcontent-ng-c3807329646="" inline-copy-host="" class="markdown markdown-main-panel stronger enable-updated-hr-color" style="--animation-duration: 400ms; --fade-animation-function: linear;" id="model-response-message-contentr_f87aebfb0f8c8e83" aria-live="off" aria-busy="false" dir="ltr"><p data-path-to-node="0">Once you have shared your project to a GitHub repository from Firebase Studio, adding it to your Chrome browser is simple. Since it is not coming from the official Web Store, you will use <b data-path-to-node="0" data-index-in-node="188">Developer Mode</b>.</p><p data-path-to-node="1">Here is the 2026 workflow to get it running:</p><h3 data-path-to-node="2">1. Download the Code from GitHub</h3><ol start="1" data-path-to-node="3"><li><p data-path-to-node="3,0,0">Go to your repository on GitHub.</p></li><li><p data-path-to-node="3,1,0">Click the green <b data-path-to-node="3,1,0" data-index-in-node="16">Code</b> button.</p></li><li><p data-path-to-node="3,2,0">Select <b data-path-to-node="3,2,0" data-index-in-node="7">Download ZIP</b>.</p></li><li><p data-path-to-node="3,3,0"><b data-path-to-node="3,3,0" data-index-in-node="0">Important:</b> Extract (unzip) the folder to a permanent location on your computer (like a "Tools" or "Projects" folder). If you delete or move this folder later, the extension will stop working.</p></li></ol><h3 data-path-to-node="4">2. Open Chrome Extensions Manager</h3><ol start="1" data-path-to-node="5"><li><p data-path-to-node="5,0,0">In your Chrome address bar, type <code data-path-to-node="5,0,0" data-index-in-node="33">chrome://extensions/</code> and hit Enter.</p></li><li><p data-path-to-node="5,1,0">In the top right corner, find the toggle labeled <b data-path-to-node="5,1,0" data-index-in-node="49">Developer mode</b> and switch it to <b data-path-to-node="5,1,0" data-index-in-node="81">ON</b>.</p></li></ol><h3 data-path-to-node="6">3. Load the Extension</h3><ol start="1" data-path-to-node="7"><li><p data-path-to-node="7,0,0">A new bar will appear. Click the <b data-path-to-node="7,0,0" data-index-in-node="33">Load unpacked</b> button on the left.</p></li><li><p data-path-to-node="7,1,0">Navigate to the folder you just unzipped.</p></li><li><p data-path-to-node="7,2,0"><b data-path-to-node="7,2,0" data-index-in-node="0">Critical Step:</b> Select the specific folder that contains the <code data-path-to-node="7,2,0" data-index-in-node="60">manifest.json</code> file (the AI in Firebase Studio usually puts this in the "root" or the "src" folder).</p></li><li><p data-path-to-node="7,3,0">Click <b data-path-to-node="7,3,0" data-index-in-node="6">Select Folder</b>.</p></li></ol><h3 data-path-to-node="8">4. Pin and Test</h3><ol start="1" data-path-to-node="9"><li><p data-path-to-node="9,0,0">You should now see your "IntegrityScan" (or whatever you named it) in the list of extensions.</p></li><li><p data-path-to-node="9,1,0">Click the <b data-path-to-node="9,1,0" data-index-in-node="10">Puzzle Piece</b> icon next to your browser's address bar.</p></li><li><p data-path-to-node="9,2,0">Click the <b data-path-to-node="9,2,0" data-index-in-node="10">Pin</b> icon next to your extension so it stays visible.</p></li><li><p data-path-to-node="9,3,0">Navigate to a research paper and click your new button to start scanning!</p></li></ol><hr data-path-to-node="10"><h3 data-path-to-node="11">💡 Pro-Tips for 2026</h3><ul data-path-to-node="12"><li><p data-path-to-node="12,0,0"><b data-path-to-node="12,0,0" data-index-in-node="0">The "Scary" Warning:</b> Every time you restart Chrome, it may show a small pop-up saying <i data-path-to-node="12,0,0" data-index-in-node="86">"Disable developer mode extensions?"</i> Just click <b data-path-to-node="12,0,0" data-index-in-node="134">Cancel</b> or the <b data-path-to-node="12,0,0" data-index-in-node="148">X</b>. This is a standard security feature because Chrome didn't "verify" the code—since you built it yourself, it's safe!</p></li><li><p data-path-to-node="12,1,0"><b data-path-to-node="12,1,0" data-index-in-node="0">Updating your Code:</b> If you go back to Firebase Studio and make changes, push them to GitHub, and then download the new files to that same folder, you don't need to reinstall. Just go back to <code data-path-to-node="12,1,0" data-index-in-node="191">chrome://extensions/</code> and click the <b data-path-to-node="12,1,0" data-index-in-node="226">Refresh (circular arrow)</b> icon on your extension card.</p></li></ul><p data-path-to-node="13"><b data-path-to-node="13" data-index-in-node="0">Would you like me to help you write a "Bug Report" prompt for Firebase Studio in case the extension doesn't find images correctly on certain sites?</b></p></div></message-content><!----></div></structured-content-container><!----><!----><div _ngcontent-ng-c3748022998="" class="response-footer gap complete"><!----><!----><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c3748022998="" role="status" class="stopped-draft-message gds-body-l gds-italic ng-star-inserted" hidden="" wfd-invisible="true">Vous avez interrompu cette réponse</div><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c3748022998="" _nghost-ng-c3363139195="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c1883881203="" class="response-container-footer ng-tns-c1883881203-56 ng-star-inserted"><!----><!----><message-actions _ngcontent-ng-c3748022998="" footer="" _nghost-ng-c3060034751="" class="ng-tns-c3060034751-58 ng-star-inserted hide-action-bar" style=""><div _ngcontent-ng-c3060034751="" class="actions-container-v2 ng-tns-c3060034751-58"><div _ngcontent-ng-c3060034751="" class="buttons-container-v2 ng-tns-c3060034751-58 ng-star-inserted"><!----><thumb-up-button _ngcontent-ng-c3060034751="" _nghost-ng-c885881154="" class="ng-tns-c3060034751-58 ng-star-inserted"><button _ngcontent-ng-c885881154="" mat-icon-button="" mattooltip="Bonne réponse" aria-label="Bonne réponse" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger icon-button mat-unthemed" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" aria-pressed="false" jslog="173913;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_f87aebfb0f8c8e83&quot;,&quot;c_900130c3d9008f9e&quot;,null,&quot;rc_c052b5b00b172240&quot;,null,null,&quot;en&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-md