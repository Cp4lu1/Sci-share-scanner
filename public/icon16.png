t="32" x="0" y="0"></rect></clippath><lineargradient id="__lottie_element_741" spreadMethod="pad" gradientUnits="userSpaceOnUse"><stop></stop><stop></stop><stop></stop><stop></stop><stop></stop></lineargradient><lineargradient id="__lottie_element_748" spreadMethod="pad" gradientUnits="userSpaceOnUse"><stop></stop><stop></stop><stop></stop></lineargradient><lineargradient id="__lottie_element_752" spreadMethod="pad" gradientUnits="userSpaceOnUse"><stop></stop><stop></stop><stop></stop></lineargradient><lineargradient id="__lottie_element_756" spreadMethod="pad" gradientUnits="userSpaceOnUse" x1="0" y1="-16" x2="16" y2="0"><stop offset="1%" stop-color="rgb(49,134,255)"></stop><stop offset="50%" stop-color="rgb(49,134,255)"></stop><stop offset="100%" stop-color="rgb(49,134,255)"></stop></lineargradient><lineargradient id="__lottie_element_760" spreadMethod="pad" gradientUnits="userSpaceOnUse" x1="0" y1="-16" x2="0" y2="16"><stop offset="40%" stop-color="rgb(49,134,255)"></stop><stop offset="54%" stop-color="rgb(24,149,219)"></stop><stop offset="67%" stop-color="rgb(0,165,183)"></stop><stop offset="82%" stop-color="rgb(7,176,139)"></stop><stop offset="98%" stop-color="rgb(14,188,95)"></stop></lineargradient><lineargradient id="__lottie_element_764" spreadMethod="pad" gradientUnits="userSpaceOnUse" x1="-16" y1="0" x2="16" y2="0"><stop offset="0%" stop-color="rgb(49,134,255)"></stop><stop offset="50%" stop-color="rgb(49,134,255)"></stop><stop offset="100%" stop-color="rgb(49,134,255)"></stop><stop offset="100%" stop-color="rgb(49,134,255)"></stop><stop offset="100%" stop-color="rgb(49,134,255)"></stop></lineargradient></defs><g clip-path="url(#__lottie_element_737)"><g style="display: block;" transform="matrix(1,0,0,1,16,16)" opacity="1"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_764)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M-4.383999824523926,-14.347999572753906 C-2.996999979019165,-14.772000312805176 -1.524999976158142,-15 0,-15 C0,-15 0,-15 0,-15 C1.7100000381469727,-15 3.3540000915527344,-14.713000297546387 4.886000156402588,-14.1850004196167"></path></g></g><g style="display: none;" transform="matrix(1,0,0,1,16,16)" opacity="1" wfd-invisible="true"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_760)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M-4.500999927520752,-14.312000274658203 C-3.0799999237060547,-14.758999824523926 -1.5679999589920044,-15 0,-15 C0,-15 0,-15 0,-15 C1.6670000553131104,-15 3.2709999084472656,-14.72700023651123 4.769999980926514,-14.223999977111816"></path></g></g><g style="display: none;" transform="matrix(1,0,0,1,16,16)" opacity="1" wfd-invisible="true"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_756)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M-4.724999904632568,-14.23900032043457 C-3.239000082015991,-14.732999801635742 -1.6510000228881836,-15 0,-15 C0,-15 0,-15 0,-15 C1.5880000591278076,-15 3.118000030517578,-14.753000259399414 4.554999828338623,-14.295000076293945"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_752)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_748)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_741)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g></g></svg></div></div></bard-avatar><!----><!----></div><!----><div _ngcontent-ng-c1883881203="" class="response-container-content ng-tns-c1883881203-36"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c3748022998="" class="response-content ng-tns-c1883881203-36"><!----><div _ngcontent-ng-c3748022998="" class="thoughts-container ng-star-inserted"><!----></div><!----><!----><!----><!----><!----><h2 _ngcontent-ng-c3748022998="" class="cdk-visually-hidden ng-star-inserted">Gemini a dit</h2><!----><!----><structured-content-container _ngcontent-ng-c3748022998="" class="model-response-text processing-state-visible ng-star-inserted" _nghost-ng-c4085131935="" style="height: auto;"><div _ngcontent-ng-c4085131935="" class="container"><message-content _ngcontent-ng-c4085131935="" _nghost-ng-c3807329646="" id="message-content-id-r_fcd0ec39f999f82c" class="ng-star-inserted"><div _ngcontent-ng-c3807329646="" inline-copy-host="" class="markdown markdown-main-panel stronger enable-updated-hr-color" style="--animation-duration: 400ms; --fade-animation-function: linear;" id="model-response-message-contentr_fcd0ec39f999f82c" aria-live="off" aria-busy="false" dir="ltr"><p data-path-to-node="0">While the Chrome extension we’re building is great for "spot-checking" individual images while browsing, the best <b data-path-to-node="0" data-index-in-node="114">free</b> option for a full publication analysis (scanning the whole PDF for duplications or manipulation) in 2026 is a combination of <b data-path-to-node="0" data-index-in-node="244">Hugging Face Open-Source Detectors</b> and <b data-path-to-node="0" data-index-in-node="283">Forensically</b>.</p><p data-path-to-node="1">Unlike the $5,000/year corporate tools, these are free, but they require a tiny bit more manual oversight.</p><hr data-path-to-node="2"><h2 data-path-to-node="3">🏆 Top Free Options for Full Publication Analysis</h2><h3 data-path-to-node="4">1. The "Powerhouse" Combo: Forensically + Hugging Face</h3><p data-path-to-node="5">For a full paper, don't just look at one image. Use these in order:</p><ul data-path-to-node="6"><li><p data-path-to-node="6,0,0"><b data-path-to-node="6,0,0" data-index-in-node="0">Hugging Face (Scientific Image Integrity Space):</b> Look for the "Scientific Image Fraud Detector" spaces. In 2026, researchers have hosted open-source versions of models like <b data-path-to-node="6,0,0" data-index-in-node="173">DinoLizer</b> or <b data-path-to-node="6,0,0" data-index-in-node="186">DJIN</b> here. They are trained specifically to find spliced cells or Western blots.</p></li><li><p data-path-to-node="6,1,0"><b data-path-to-node="6,1,0" data-index-in-node="0">Forensically (Best for Manual Proof):</b> Use the <b data-path-to-node="6,1,0" data-index-in-node="46">"Clone Detector"</b> tool. If an author copied a cluster of cells from the left side of a photo to the right to make it look "fuller," Forensically will draw lines connecting the identical pixels.</p></li></ul><h3 data-path-to-node="7">2. Winston AI (Best for "AI-Generated" Detection)</h3><p data-path-to-node="8">If you suspect the images were entirely made up by a Generative AI (like Midjourney or DALL-E) rather than just "Photoshopped":</p><ul data-path-to-node="9"><li><p data-path-to-node="9,0,0"><b data-path-to-node="9,0,0" data-index-in-node="0">Pros:</b> High accuracy for 2026 diffusion models; provides a "confidence score."</p></li><li><p data-path-to-node="9,1,0"><b data-path-to-node="9,1,0" data-index-in-node="0">Cons:</b> Free tier is limited to a certain number of scans per month.</p></li></ul><h3 data-path-to-node="10">3. FotoForensics (Best for Metadata &amp; Compression)</h3><p data-path-to-node="11">If you have the original file (not a screenshot):</p><ul data-path-to-node="12"><li><p data-path-to-node="12,0,0"><b data-path-to-node="12,0,0" data-index-in-node="0">The "ELA" (Error Level Analysis):</b> If an image is 100% original, the "noise" in the ELA view should be uniform. If one part of the image (like a specific band in a gel) is much brighter/sharper than the rest, it was likely pasted in later.</p></li></ul><hr data-path-to-node="13"><h2 data-path-to-node="14">📊 Quick Comparison: Free vs. Paid</h2><div class="horizontal-scroll-wrapper"><div class="table-block-component"><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><table-block _nghost-ng-c2976694548="" class="ng-star-inserted"><div _ngcontent-ng-c2976694548="" class="table-block has-export-button new-table-style is-at-scroll-start is-at-scroll-end"><div _ngcontent-ng-c2976694548="" not-end-of-paragraph="" class="table-content not-end-of-paragraph" jslog="275421;track:impression,attention" data-hveid="0" decode-data-ved="1" data-ved="0CAAQ3ecQahcKEwihq_2QlpqTAxUAAAAAHQAAAAAQeg"><table data-path-to-node="15"><thead><tr><td><span data-path-to-node="15,0,0,0">Feature</span></td><td><span data-path-to-node="15,0,1,0"><b data-path-to-node="15,0,1,0" data-index-in-node="0">Your Free Setup</b> (Forensically/HF)</span></td><td><span data-path-to-node="15,0,2,0"><b data-path-to-node="15,0,2,0" data-index-in-node="0">Paid Tools</b> (Proofig/ImageTwin)</span></td></tr></thead><tbody><tr><td><span data-path-to-node="15,1,0,0"><b data-path-to-node="15,1,0,0" data-index-in-node="0">Cross-Paper Check</b></span></td><td><span data-path-to-node="15,1,1,0">Manual (Reverse Image Search)</span></td><td><span data-path-to-node="15,1,2,0"><b data-path-to-node="15,1,2,0" data-index-in-node="0">Automated</b> (Scans 50M+ papers)</span></td></tr><tr><td><span data-path-to-node="15,2,0,0"><b data-path-to-node="15,2,0,0" data-index-in-node="0">Splicing Detection</b></span></td><td><span data-path-to-node="15,2,1,0">Manual Filters (ELA/Clone)</span></td><td><span data-path-to-node="15,2,2,0"><b data-path-to-node="15,2,2,0" data-index-in-node="0">Automated</b> AI Flags</span></td></tr><tr><td><span data-path-to-node="15,3,0,0"><b data-path-to-node="15,3,0,0" data-index-in-node="0">Cost</b></span></td><td><span data-path-to-node="15,3,1,0"><b data-path-to-node="15,3,1,0" data-index-in-node="0">$0</b></span></td><td><span data-path-to-node="15,3,2,0"><b data-path-to-node="15,3,2,0" data-index-in-node="0">$500+ per paper/sub</b></span></td></tr><tr><td><span data-path-to-node="15,4,0,0"><b data-path-to-node="15,4,0,0" data-index-in-node="0">Privacy</b></span></td><td><span data-path-to-node="15,4,1,0">Your images are public on most free sites</span></td><td><span data-path-to-node="15,4,2,0">Private &amp; Confidential</span></td></tr></tbody></table></div><div _ngcontent-ng-c2976694548="" hide-from-message-actions="" class="table-footer hide-from-message-actions"><button _ngcontent-ng-c2976694548="" mat-button="" class="mdc-button mat-mdc-button-base export-sheets-button-container mat-mdc-button mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" jslog="184701;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_fcd0ec39f999f82c&quot;,&quot;c_900130c3d9008f9e&quot;,null,null,null,null,null,null,1,null,null,null,0]]"><span class="mat-mdc-button-persistent-ripple mdc-button__ripple"></span><span class="mdc-button__label"><span _ngcontent-ng-c2976694548="" class="export-sheets-button"><span _ngcontent-ng-c2976694548="" class="export-sheets-icon"><mat-icon _ngcontent-ng-c2976694548="" role="img" fonticon="drive_spreadsheet" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="drive_spreadsheet"></mat-icon></span><span _ngcontent-ng-c2976694548="">Exporter vers Sheets</span></span></span><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><button _ngcontent-ng-c2976694548="" mat-icon-button="" mattooltip="Copier le tableau" aria-label="Copier le tableau" data-test-id="copy-table-button" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="276666;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_fcd0ec39f999f82c&quot;,&quot;c_900130c3d9008f9e&quot;,null,null,null,null,null,null,1,null,null,null,0]]"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c2976694548="" role="img" fonticon="content_copy" class="mat-icon notranslate gds-icon-l google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----></div></div><!----></table-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element></div></div><hr data-path-to-node="16"><h2 data-path-to-node="17">💡 The "Secret" Strategy for 2026</h2><p data-path-to-node="18">If you want a <b data-path-to-node="18" data-index-in-node="14">full publication scan</b> for free, do this:</p><ol start="1" data-path-to-node="19"><li><p data-path-to-node="19,0,0"><b data-path-to-node="19,0,0" data-index-in-node="0">Extract the Images:</b> Use a free PDF image extractor (or your new Chrome Extension) to grab every figure.</p></li><li><p data-path-to-node="19,1,0"><b data-path-to-node="19,1,0" data-index-in-node="0">Bulk Reverse Search:</b> Use <b data-path-to-node="19,1,0" data-index-in-node="25">Google Lens</b> or <b data-path-to-node="19,1,0" data-index-in-node="40">TinEye</b> on the most "important" figures. This is the #1 way to find if the image was stolen from an older paper (plagiarism).</p></li><li><p data-path-to-node="19,2,0"><b data-path-to-node="19,2,0" data-index-in-node="0">Run the Extension:</b> Use the extension we are building to quickly push the most suspicious ones into <b data-path-to-node="19,2,0" data-index-in-node="99">Forensically</b> for pixel-level proof.</p></li></ol><p data-path-to-node="20"><b data-path-to-node="20" data-index-in-node="0">Would you like me to help you refine the "Bulk Scan" script so it automatically downloads all images into a folder for you to upload to these tools?</b></p></div></message-content><!----></div></structured-content-container><!----><!----><div _ngcontent-ng-c3748022998="" class="response-footer gap complete"><!----><!----><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c3748022998="" role="status" class="stopped-draft-message gds-body-l gds-italic ng-star-inserted" hidden="" wfd-invisible="true">Vous avez interrompu cette réponse</div><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c3748022998="" _nghost-ng-c3363139195="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c1883881203="" class="response-container-footer ng-tns-c1883881203-36 ng-star-inserted"><!----><!----><message-actions _ngcontent-ng-c3748022998="" footer="" _nghost-ng-c3060034751="" class="ng-tns-c3060034751-38 ng-star-inserted hide-action-bar" style=""><div _ngcontent-ng-c3060034751="" class="actions-container-v2 ng-tns-c3060034751-38"><div _ngcontent-ng-c3060034751="" class="buttons-container-v2 ng-tns-c3060034751-38 ng-star-inserted"><!----><thumb-up-button _ngcont