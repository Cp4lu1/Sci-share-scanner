set="67%" stop-color="rgb(0,165,183)"></stop><stop offset="82%" stop-color="rgb(7,176,139)"></stop><stop offset="98%" stop-color="rgb(14,188,95)"></stop></lineargradient><lineargradient id="__lottie_element_892" spreadMethod="pad" gradientUnits="userSpaceOnUse" x1="-16" y1="0" x2="16" y2="0"><stop offset="0%" stop-color="rgb(49,134,255)"></stop><stop offset="50%" stop-color="rgb(49,134,255)"></stop><stop offset="100%" stop-color="rgb(49,134,255)"></stop><stop offset="100%" stop-color="rgb(49,134,255)"></stop><stop offset="100%" stop-color="rgb(49,134,255)"></stop></lineargradient></defs><g clip-path="url(#__lottie_element_865)"><g style="display: block;" transform="matrix(1,0,0,1,16,16)" opacity="1"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_892)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M-4.383999824523926,-14.347999572753906 C-2.996999979019165,-14.772000312805176 -1.524999976158142,-15 0,-15 C0,-15 0,-15 0,-15 C1.7100000381469727,-15 3.3540000915527344,-14.713000297546387 4.886000156402588,-14.1850004196167"></path></g></g><g style="display: none;" transform="matrix(1,0,0,1,16,16)" opacity="1" wfd-invisible="true"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_888)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M-14.626999855041504,3.3369998931884766 C-14.871000289916992,2.2639999389648438 -15,1.1469999551773071 -15,0 C-15,-5.877999782562256 -11.612000465393066,-10.970999717712402 -6.684000015258789,-13.430000305175781"></path></g></g><g style="display: none;" transform="matrix(1,0,0,1,16,16)" opacity="1" wfd-invisible="true"><g opacity="1" transform="matrix(1,0,0,1,0,0)"><path stroke="url(#__lottie_element_884)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4" stroke-opacity="1" stroke-width="2" d=" M-4.492000102996826,-14.3149995803833 C-3.0739998817443848,-14.760000228881836 -1.565000057220459,-15 0,-15 C0,-15 0,-15 0,-15 C1.6710000038146973,-15 3.2780001163482666,-14.72599983215332 4.7789998054504395,-14.220999717712402"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_880)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_876)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_869)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g></g></svg></div></div></bard-avatar><!----><!----></div><!----><div _ngcontent-ng-c1883881203="" class="response-container-content ng-tns-c1883881203-41"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c3748022998="" class="response-content ng-tns-c1883881203-41"><!----><div _ngcontent-ng-c3748022998="" class="thoughts-container ng-star-inserted"><!----></div><!----><!----><!----><!----><!----><h2 _ngcontent-ng-c3748022998="" class="cdk-visually-hidden ng-star-inserted">Gemini a dit</h2><!----><!----><structured-content-container _ngcontent-ng-c3748022998="" class="model-response-text processing-state-visible ng-star-inserted" _nghost-ng-c4085131935="" style="height: auto;"><div _ngcontent-ng-c4085131935="" class="container"><message-content _ngcontent-ng-c4085131935="" _nghost-ng-c3807329646="" id="message-content-id-r_32123112f603c86f" class="ng-star-inserted"><div _ngcontent-ng-c3807329646="" inline-copy-host="" class="markdown markdown-main-panel stronger enable-updated-hr-color" style="--animation-duration: 400ms; --fade-animation-function: linear;" id="model-response-message-contentr_32123112f603c86f" aria-live="off" aria-busy="false" dir="ltr"><p data-path-to-node="0">I understand perfectly now. You aren't just looking for a "shortcut" to other websites; you want a tool that performs <b data-path-to-node="0" data-index-in-node="118">comparative analysis</b> (finding if Figure 1A is a stretched version of Figure 3C) and <b data-path-to-node="0" data-index-in-node="202">manipulation detection</b> (identifying if a gel band has been widened or "cleaned up").</p><p data-path-to-node="1">The reason tools like <b data-path-to-node="1" data-index-in-node="22">Proofig</b> and <b data-path-to-node="1" data-index-in-node="34">ImageTwin</b> are expensive is that they use a "Comparison Engine" that checks every image against every other image in the same PDF.</p><p data-path-to-node="2">To do this for free without coding in 2026, we will use <b data-path-to-node="2" data-index-in-node="56">Firebase Studio</b> to build a "Smart Collector" and connect it to a free <b data-path-to-node="2" data-index-in-node="126">Computer Vision API</b>.</p><hr data-path-to-node="3"><h2 data-path-to-node="4">🛠️ The "Integrity Suite" Setup</h2><h3 data-path-to-node="5">Step 1: Create the Project in Firebase Studio</h3><p data-path-to-node="6">Go to <response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><link-block _nghost-ng-c1796846746="" class="ng-star-inserted"><!----><!----><a _ngcontent-ng-c1796846746="" target="_blank" rel="noopener" externallink="" _nghost-ng-c412475248="" jslog="197247;track:generic_click,impression,attention;BardVeMetadataKey:[[&quot;r_32123112f603c86f&quot;,&quot;c_900130c3d9008f9e&quot;,null,&quot;rc_7c0f206020ba99b4&quot;,null,null,&quot;en&quot;,null,1,null,null,1,0]]" href="https://studio.firebase.google.com/" class="ng-star-inserted" data-hveid="0" decode-data-ved="1" data-ved="0CAAQ_4QMahgKEwihq_2QlpqTAxUAAAAAHQAAAAAQkwE">Firebase Studio</a><!----></link-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element> and start a new <b data-path-to-node="6" data-index-in-node="38">Chrome Extension</b> project.</p><h3 data-path-to-node="7">Step 2: The "Master Prompt" for the AI Agent</h3><p data-path-to-node="8">Paste this into the chat. It instructs the AI to build the "brain" for duplication and transformation checks:</p><blockquote data-path-to-node="9"><p data-path-to-node="9,0">"Build a Chrome Extension called 'IntegrityScan'.</p><ol start="1" data-path-to-node="9,1"><li><p data-path-to-node="9,1,0,0"><b data-path-to-node="9,1,0,0" data-index-in-node="0">Content Script:</b> It must find all images on the page and extract their 'Pixel Data' (using a Canvas element) to generate a <b data-path-to-node="9,1,0,0" data-index-in-node="122">Perceptual Hash (pHash)</b> for each image.</p></li><li><p data-path-to-node="9,1,1,0"><b data-path-to-node="9,1,1,0" data-index-in-node="0">Duplication Logic:</b> Compare the hashes of all images on the page. If two images have a similarity &gt; 90%, flag them as 'Potential Duplicates'.</p></li><li><p data-path-to-node="9,1,2,0"><b data-path-to-node="9,1,2,0" data-index-in-node="0">Transformation Logic:</b> Check for different aspect ratios of images with similar hashes. If an image has the same hash but different dimensions, flag it as 'Potential Transformation/Widening'.</p></li><li><p data-path-to-node="9,1,3,0"><b data-path-to-node="9,1,3,0" data-index-in-node="0">UI:</b> Create a popup that shows a gallery of all images found. Highlight duplicates in RED and transformations in YELLOW.</p></li><li><p data-path-to-node="9,1,4,0"><b data-path-to-node="9,1,4,0" data-index-in-node="0">External Analysis:</b> Add a button 'Check Splicing' that sends the image to <code data-path-to-node="9,1,4,0" data-index-in-node="73">https://29a.ch/photo-forensics/</code> for ELA analysis."</p></li></ol></blockquote><hr data-path-to-node="10"><h2 data-path-to-node="11">🔬 How the "No-Code" Logic Works</h2><p data-path-to-node="12">Since you aren't coding, here is the "magic" the AI is doing for you:</p><ul data-path-to-node="13"><li><p data-path-to-node="13,0,0"><b data-path-to-node="13,0,0" data-index-in-node="0">Perceptual Hashing (pHash):</b> Unlike a normal file hash, a pHash stays almost the same even if an image is <b data-path-to-node="13,0,0" data-index-in-node="105">resized, widened, or compressed</b>. This is how the extension catches an author who uses the same Western Blot twice but stretches one of them.</p></li><li><p data-path-to-node="13,1,0"><b data-path-to-node="13,1,0" data-index-in-node="0">Canvas Fingerprinting:</b> The extension "draws" the images into an invisible box in your browser to analyze the pixels directly, allowing it to work even on secured PDFs viewed in the browser.</p></li></ul><hr data-path-to-node="14"><h2 data-path-to-node="15">🚀 Step-by-Step Installation</h2><ol start="1" data-path-to-node="16"><li><p data-path-to-node="16,0,0"><b data-path-to-node="16,0,0" data-index-in-node="0">Generate Files:</b> After you give the prompt, Firebase Studio will generate <code data-path-to-node="16,0,0" data-index-in-node="73">manifest.json</code>, <code data-path-to-node="16,0,0" data-index-in-node="88">content.js</code>, and <code data-path-to-node="16,0,0" data-index-in-node="104">popup.html</code>.</p></li><li><p data-path-to-node="16,1,0"><b data-path-to-node="16,1,0" data-index-in-node="0">Download &amp; Unzip:</b> Download the project as a <code data-path-to-node="16,1,0" data-index-in-node="44">.zip</code> and extract it.</p></li><li><p data-path-to-node="16,2,0"><b data-path-to-node="16,2,0" data-index-in-node="0">Load into Chrome:</b></p><ul data-path-to-node="16,2,1"><li><p data-path-to-node="16,2,1,0,0">Go to <code data-path-to-node="16,2,1,0,0" data-index-in-node="6">chrome://extensions/</code>.</p></li><li><p data-path-to-node="16,2,1,1,0">Enable <b data-path-to-node="16,2,1,1,0" data-index-in-node="7">Developer Mode</b>.</p></li><li><p data-path-to-node="16,2,1,2,0">Click <b data-path-to-node="16,2,1,2,0" data-index-in-node="6">Load Unpacked</b> and select your folder.</p></li></ul></li><li><p data-path-to-node="16,3,0"><b data-path-to-node="16,3,0" data-index-in-node="0">The Scan:</b></p><ul data-path-to-node="16,3,1"><li><p data-path-to-node="16,3,1,0,0">Open a research paper (HTML or PDF in-browser).</p></li><li><p data-path-to-node="16,3,1,1,0">Click the <b data-path-to-node="16,3,1,1,0" data-index-in-node="10">IntegrityScan</b> icon.</p></li><li><p data-path-to-node="16,3,1,2,0">The extension will instantly map every image and show you if any two figures are "mathematically" too similar.</p></li></ul></li></ol><hr data-path-to-node="17"><h2 data-path-to-node="18">📊 Feature Comparison</h2><div class="horizontal-scroll-wrapper"><div class="table-block-component"><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><table-block _nghost-ng-c2976694548="" class="ng-star-inserted"><div _ngcontent-ng-c2976694548="" class="table-block has-export-button new-table-style is-at-scroll-start is-at-scroll-end"><div _ngcontent-ng-c2976694548="" not-end-of-paragraph="" class="table-content not-end-of-paragraph" jslog="275421;track:impression,attention" data-hveid="0" decode-data-ved="1" data-ved="0CAAQ3ecQahgKEwihq_2QlpqTAxUAAAAAHQAAAAAQlAE"><table data-path-to-node="19"><thead><tr><td><span data-path-to-node="19,0,0,0">Check Type</span></td><td><span data-path-to-node="19,0,1,0">How Your Extension Does It</span></td><td><span data-path-to-node="19,0,2,0">Detects...</span></td></tr></thead><tbody><tr><td><span data-path-to-node="19,1,0,0"><b data-path-to-node="19,1,0,0" data-index-in-node="0">Duplication</b></span></td><td><span data-path-to-node="19,1,1,0">pHash Comparison</span></td><td><span data-path-to-node="19,1,2,0">Same image used twice in one paper.</span></td></tr><tr><td><span data-path-to-node="19,2,0,0"><b data-path-to-node="19,2,0,0" data-index-in-node="0">Transformation</b></span></td><td><span data-path-to-node="19,2,1,0">Aspect Ratio Analysis</span></td><td><span data-path-to-node="19,2,2,0">Widened, squashed, or rotated images.</span></td></tr><tr><td><span data-path-to-node="19,3,0,0"><b data-path-to-node="19,3,0,0" data-index-in-node="0">Manipulation</b></span></td><td><span data-path-to-node="19,3,1,0">ELA (via Forensically)</span></td><td><span data-path-to-node="19,3,2,0">"Cleaned" backgrounds or pasted bands.</span></td></tr><tr><td><span data-path-to-node="19,4,0,0"><b data-path-to-node="19,4,0,0" data-index-in-node="0">Plagiarism</b></span></td><td><span data-path-to-node="19,4,1,0">Reverse Image Search</span></td><td><span data-path-to-node="19,4,2,0">Images stolen from <i data-path-to-node="19,4,2,0" data-index-in-node="19">other</i> papers.</span></td></tr></tbody></table></div><div _ngcontent-ng-c2976694548="" hide-from-message-actions="" class="table-footer hide-from-message-actions"><button _ngcontent-ng-c2976694548="" mat-button="" class="mdc-button mat-mdc-button-base export-sheets-button-container mat-mdc-button mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" jslog="184701;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_32123112f603c86f&quot;,&quot;c_900130c3d9008f9e&quot;,null,null,null,null,null,null,1,null,null,null,0]]"><span class="mat-mdc-button-persistent-ripple mdc-button__ripple"></span><span class="mdc-button__label"><span _ngcontent-ng-c2976694548="" class="export-sheets-button"><span _ngcontent-ng-c2976694548="" class="export-sheets-icon"><mat-icon _ngcontent-ng-c2976694548="" role="img" fonticon="drive_spreadsheet" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="drive_spreadsheet"></mat-icon></span><span _ngcontent-ng-c2976694548="">Exporter vers Sheets</span></span></span><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><button _ngcontent-ng-c2976694548="" mat-icon-button="" mattooltip="Copier le tableau" aria-label="Copier le tableau" data-test-id="copy-table-button" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="276666;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_32123112f603c86f&quot;,&quot;c_900130c3d9008f9e&quot;,null,null,null,null,null,null,1,null,null,null,0]]"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c2976694548="" role="img" fonticon="content_copy" class="mat-icon notranslate gds-icon-l google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----></div></div><!----></table-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element></div></div><hr data-path-to-node="20"><h3 data-path-to-node="21">⚠️ A Critical Limitation (The "Database" Problem)</h3><p data-path-to-node="22">Your extension will be excellent at finding <b data-path-to-node="22" data-index-in-node="44">Internal Duplicates</b> (errors within the same paper). However, it cannot see if an image was stolen from a <i data-path-to-node="22" data-index-in-node="149">different</i> paper published three years ago. Only paid tools like ImageTwin have the $100M+ database of existing papers to check against. To do that for free, you must use the <b data-path-to-node="22" data-index-in-node="323">"Search by Image"</b> button in your extension to trigger a Google Lens/TinEye search.</p><p data-path-to-node="23"><b data-path-to-node="23" data-index-in-node="0">Would you like me to provide the specific <code data-path-to-node="23" data-index-in-node="42">content.js</code> code for the duplication detector so you can ensure Firebase Studio writes the logic correctly?</b></p></div></message-content><!----></div></structured-content-container><!----><!----><div _ngcontent-ng-c3748022998="" class="response-footer gap complete"><!----><!----><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c3748022998="" role="status" class="stopped-draft-message gds-body-l gds-italic ng-star-inserted" hidden="" wfd-invisible="true">Vous avez interrompu cette réponse</div><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c3748022998="" _nghost-ng-c3363139195="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c1883881203="" class="response-container-footer ng-tns-c1883881203-41 ng-star-inserted"><!----><!----><message-actions _ngcontent-ng-c3748022998="" footer="" _nghost-ng-c3060034751="" class="ng-tns-c3060034751-43 ng-star-inserted hide-action-bar" style=""><div _ngcontent-ng-c3060034751="" class="actions-container-v2 ng-tns-c3060034751-43"><div _ngcontent-ng-c3060034751="" class="buttons-container-v2 ng-tns-c3060034751-43 ng-star-inserted"><!----><thumb-up-button _ngcontent-ng-c3060034751="" _nghost-ng-c885881154="" class="ng-tns-c3060034751-43 ng-star-inserted"><button _ngcontent-ng-c885881154="" mat-icon-button="" mattooltip="Bonne réponse" aria-label="Bonne réponse" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger icon-button mat-unthemed" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" aria-pressed="false" jslog="173913;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_32123112f603c86f&quot;,&quot;c_900130c3d9008f9e&quot;,null,&quot;rc_7c0f206020ba99b4&quot;,null,null,&quot;en&quot;,null,1,null,null,1,0]];mutable:true"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c885881154="" role="img" fonticon="thumb_up" class="mat-icon notranslate gds-icon-m google-symbols mat-ligature-font mat-icon-no-color ng-star-inserted" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="thumb_up"></mat-icon><!----><div _ngcontent-ng-c885881154="" lottie-animation="" class="thumb-animation" hidden="" wfd-invisible="true"><svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 96 96" width="96" height="96" preserveAspectRatio="xMidYMid meet" style="width: 100%; height: 100%; transform: translate3d(0px, 0px, 0px); content-visibility: visible;"><defs><clippath id="__lottie_element_896"><rect width="96" height="96" x="0" y="0"></rect></clippath><mask id="__lottie_element_900"><rect fill="#ffffff" width="96" height="96"></rect><path fill="#000000" clip-rule="nonzero" d=" M20.823999404907227,-50.45800018310547 C20.823999404907227,-50.45800