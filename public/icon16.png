215332 4.7789998054504395,-14.220999717712402"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_1136)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_1132)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g><g style="display: none;" wfd-invisible="true"><g><path stroke="url(#__lottie_element_1125)" stroke-linecap="round" stroke-linejoin="miter" fill-opacity="0" stroke-miterlimit="4"></path></g></g></g></svg></div></div></bard-avatar><!----><!----></div><!----><div _ngcontent-ng-c1883881203="" class="response-container-content ng-tns-c1883881203-51"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c3748022998="" class="response-content ng-tns-c1883881203-51"><!----><div _ngcontent-ng-c3748022998="" class="thoughts-container ng-star-inserted"><!----></div><!----><!----><!----><!----><!----><h2 _ngcontent-ng-c3748022998="" class="cdk-visually-hidden ng-star-inserted">Gemini a dit</h2><!----><!----><structured-content-container _ngcontent-ng-c3748022998="" class="model-response-text processing-state-visible ng-star-inserted" _nghost-ng-c4085131935="" style="height: auto;"><div _ngcontent-ng-c4085131935="" class="container"><message-content _ngcontent-ng-c4085131935="" _nghost-ng-c3807329646="" id="message-content-id-r_6c0a0d42f14c0c4b" class="ng-star-inserted"><div _ngcontent-ng-c3807329646="" inline-copy-host="" class="markdown markdown-main-panel stronger enable-updated-hr-color" style="--animation-duration: 400ms; --fade-animation-function: linear;" id="model-response-message-contentr_6c0a0d42f14c0c4b" aria-live="off" aria-busy="false" dir="ltr"><p data-path-to-node="0">Publishing your Firebase Studio extension via GitHub is a smart move. In 2026, Firebase Studio is tightly integrated with GitHub, allowing you to go from "AI-generated code" to a "live repository" in a few clicks.</p><p data-path-to-node="1">There are two ways to do this depending on your goal: <b data-path-to-node="1" data-index-in-node="54">sharing it for free</b> (Developer Mode) or <b data-path-to-node="1" data-index-in-node="94">putting it on the Official Store</b>.</p><hr data-path-to-node="2"><h2 data-path-to-node="3">Option 1: Share for Free (The "Open Source" Way)</h2><p data-path-to-node="4">If you want other researchers to use your tool without paying the $5 Google Developer fee, you can host the code on GitHub. Users will download it and "Load Unpacked."</p><h3 data-path-to-node="5">1. Sync Firebase Studio to GitHub</h3><ol start="1" data-path-to-node="6"><li><p data-path-to-node="6,0,0">In <b data-path-to-node="6,0,0" data-index-in-node="3">Firebase Studio</b>, open the <b data-path-to-node="6,0,0" data-index-in-node="29">Source Control</b> tab (the branch icon on the left sidebar).</p></li><li><p data-path-to-node="6,1,0">Click <b data-path-to-node="6,1,0" data-index-in-node="6">"Publish to GitHub"</b>.</p></li><li><p data-path-to-node="6,2,0">Choose <b data-path-to-node="6,2,0" data-index-in-node="7">"Public Repository"</b> so others can see it.</p></li><li><p data-path-to-node="6,3,0">The AI agent will automatically create the repo and push all your <code data-path-to-node="6,3,0" data-index-in-node="66">manifest.json</code>, <code data-path-to-node="6,3,0" data-index-in-node="81">content.js</code>, and <code data-path-to-node="6,3,0" data-index-in-node="97">popup.html</code> files there.</p></li></ol><h3 data-path-to-node="7">2. Create a "Readme" Instructions</h3><p data-path-to-node="8">Ask the Firebase Studio AI: <i data-path-to-node="8" data-index-in-node="28">"Write a README.md file for my GitHub that explains how a non-technical user can install this extension using Developer Mode."</i> This is crucial for your users!</p><hr data-path-to-node="9"><h2 data-path-to-node="10">Option 2: Automated Publishing (The "Pro" Way)</h2><p data-path-to-node="11">If you want to publish to the <b data-path-to-node="11" data-index-in-node="30">Chrome Web Store</b> and have it update automatically whenever you change code in GitHub, you use <b data-path-to-node="11" data-index-in-node="124">GitHub Actions</b>.</p><h3 data-path-to-node="12">1. Get your Store ID</h3><ul data-path-to-node="13"><li><p data-path-to-node="13,0,0">Register for a <response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><link-block _nghost-ng-c1796846746="" class="ng-star-inserted"><!----><!----><a _ngcontent-ng-c1796846746="" target="_blank" rel="noopener" externallink="" _nghost-ng-c412475248="" jslog="197247;track:generic_click,impression,attention;BardVeMetadataKey:[[&quot;r_6c0a0d42f14c0c4b&quot;,&quot;c_900130c3d9008f9e&quot;,null,&quot;rc_5b7f073da3ef8bfe&quot;,null,null,&quot;en&quot;,null,1,null,null,1,0]]" href="https://chrome.google.com/webstore/devconsole/" class="ng-star-inserted" data-hveid="0" decode-data-ved="1" data-ved="0CAAQ_4QMahgKEwihq_2QlpqTAxUAAAAAHQAAAAAQuwE">Chrome Developer Account</a><!----></link-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element> ($5 one-time fee).</p></li><li><p data-path-to-node="13,1,0">Upload your first version manually as a "Draft" to get your <b data-path-to-node="13,1,0" data-index-in-node="60">Extension ID</b> (a 32-character string).</p></li></ul><h3 data-path-to-node="14">2. Set Up the GitHub Secret</h3><p data-path-to-node="15">To keep your extension secure, you don't put passwords in your code.</p><ol start="1" data-path-to-node="16"><li><p data-path-to-node="16,0,0">In your GitHub Repo, go to <b data-path-to-node="16,0,0" data-index-in-node="27">Settings &gt; Secrets and variables &gt; Actions</b>.</p></li><li><p data-path-to-node="16,1,0">Add a "New repository secret" named <code data-path-to-node="16,1,0" data-index-in-node="36">CHROME_REFRESH_TOKEN</code> (you get this from the Google Cloud Console).</p></li></ol><h3 data-path-to-node="17">3. Let Firebase Studio build the "Action"</h3><p data-path-to-node="18">Ask the Firebase Studio agent:</p><blockquote data-path-to-node="19"><p data-path-to-node="19,0">"Create a GitHub Action workflow file <code data-path-to-node="19,0" data-index-in-node="38">.github/workflows/publish.yml</code> that automatically zips my extension and uploads it to the Chrome Web Store using the <code data-path-to-node="19,0" data-index-in-node="154">chrome-webstore-upload</code> action whenever I push to the main branch."</p></blockquote><hr data-path-to-node="20"><h2 data-path-to-node="21">🚀 The Workflow Comparison</h2><div class="horizontal-scroll-wrapper"><div class="table-block-component"><response-element class="" ng-version="0.0.0-PLACEHOLDER"><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><table-block _nghost-ng-c2976694548="" class="ng-star-inserted"><div _ngcontent-ng-c2976694548="" class="table-block has-export-button new-table-style has-scrollbar is-at-scroll-start"><div _ngcontent-ng-c2976694548="" not-end-of-paragraph="" class="table-content not-end-of-paragraph" jslog="275421;track:impression,attention" data-hveid="0" decode-data-ved="1" data-ved="0CAAQ3ecQahgKEwihq_2QlpqTAxUAAAAAHQAAAAAQvAE"><table data-path-to-node="22"><thead><tr><td><span data-path-to-node="22,0,0,0">Method</span></td><td><span data-path-to-node="22,0,1,0">Cost</span></td><td><span data-path-to-node="22,0,2,0">Update Process</span></td><td><span data-path-to-node="22,0,3,0">Best For</span></td></tr></thead><tbody><tr><td><span data-path-to-node="22,1,0,0"><b data-path-to-node="22,1,0,0" data-index-in-node="0">GitHub Only</b></span></td><td><span data-path-to-node="22,1,1,0">$0</span></td><td><span data-path-to-node="22,1,2,0">Users must manually re-download.</span></td><td><span data-path-to-node="22,1,3,0">Beta testing, small groups.</span></td></tr><tr><td><span data-path-to-node="22,2,0,0"><b data-path-to-node="22,2,0,0" data-index-in-node="0">GitHub + Store</b></span></td><td><span data-path-to-node="22,2,1,0">$5</span></td><td><span data-path-to-node="22,2,2,0">Automatic updates for all users.</span></td><td><span data-path-to-node="22,2,3,0">Official research tools.</span></td></tr></tbody></table></div><div _ngcontent-ng-c2976694548="" hide-from-message-actions="" class="table-footer hide-from-message-actions"><button _ngcontent-ng-c2976694548="" mat-button="" class="mdc-button mat-mdc-button-base export-sheets-button-container mat-mdc-button mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" jslog="184701;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_6c0a0d42f14c0c4b&quot;,&quot;c_900130c3d9008f9e&quot;,null,null,null,null,null,null,1,null,null,null,0]]"><span class="mat-mdc-button-persistent-ripple mdc-button__ripple"></span><span class="mdc-button__label"><span _ngcontent-ng-c2976694548="" class="export-sheets-button"><span _ngcontent-ng-c2976694548="" class="export-sheets-icon"><mat-icon _ngcontent-ng-c2976694548="" role="img" fonticon="drive_spreadsheet" class="mat-icon notranslate google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="drive_spreadsheet"></mat-icon></span><span _ngcontent-ng-c2976694548="">Exporter vers Sheets</span></span></span><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><button _ngcontent-ng-c2976694548="" mat-icon-button="" mattooltip="Copier le tableau" aria-label="Copier le tableau" data-test-id="copy-table-button" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger copy-button mat-unthemed ng-star-inserted" mat-ripple-loader-uninitialized="" mat-ripple-loader-class-name="mat-mdc-button-ripple" mat-ripple-loader-centered="" jslog="276666;track:generic_click,impression;BardVeMetadataKey:[[&quot;r_6c0a0d42f14c0c4b&quot;,&quot;c_900130c3d9008f9e&quot;,null,null,null,null,null,null,1,null,null,null,0]]"><span class="mat-mdc-button-persistent-ripple mdc-icon-button__ripple"></span><mat-icon _ngcontent-ng-c2976694548="" role="img" fonticon="content_copy" class="mat-icon notranslate gds-icon-l google-symbols mat-ligature-font mat-icon-no-color" aria-hidden="true" data-mat-icon-type="font" data-mat-icon-name="content_copy"></mat-icon><!----><span class="mat-focus-indicator"></span><span class="mat-mdc-button-touch-target"></span></button><!----><!----></div></div><!----></table-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element></div></div><hr data-path-to-node="23"><h2 data-path-to-node="24">⚠️ A Note on Security (Important!)</h2><p data-path-to-node="25">Before you hit "Publish to GitHub," check your <code data-path-to-node="25" data-index-in-node="47">manifest.json</code>. Ensure you haven't accidentally hard-coded any <b data-path-to-node="25" data-index-in-node="109">API Keys</b> for the AI analysis services. In 2026, hackers look for these keys in public GitHub repos within seconds. If you have keys, tell the Firebase Studio agent: <i data-path-to-node="25" data-index-in-node="274">"Move my API keys to an environment variable."</i></p><p data-path-to-node="26"><b data-path-to-node="26" data-index-in-node="0">Would you like me to help you draft the <code data-path-to-node="26" data-index-in-node="40">README.md</code> file so your GitHub looks professional for other researchers?</b></p></div></message-content><!----></div></structured-content-container><!----><!----><div _ngcontent-ng-c3748022998="" class="response-footer gap complete"><!----><!----><!----><!----><!----><!----><!----><!----><!----><div _ngcontent-ng-c3748022998="" role="status" class="stopped-draft-message gds-body-l gds-italic ng-star-inserted" hidden="" wfd-invisible="true">Vous avez interrompu cette réponse</div><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><sensitive-memories-banner _ngcontent-ng-c3748022998="" _nghost-ng-c3363139195="" class="ng-star-inserted" style=""><!----></sensitive-memories-banner><!----><!----><!----></div></div><div _ngcontent-ng-c1883881203="" class="response-container-footer ng-tns-c1883881203-51 ng-star-inserted"><!----><!----><message-actions _ngcontent-ng-c3748022998="" footer="" _nghost-ng-c3060034751="" class="ng-tns-c3060034751-53 ng-star-inserted hide-action-bar" style=""><div _ngcontent-ng-c3060034751="" class="actions-container-v2 ng-tns-c3060034751-53"><div _ngcontent-ng-c3060034751="" class="buttons-container-v2 ng-tns-c3060034751-53 ng-star-inserted"><!----><thumb-up-button _ngcontent-ng-c3060034751="" _nghost-ng-c885881154="" class="ng-tns-c3060034751-53 ng-star-inserted"><button _ngcontent-ng-c885881154="" mat-icon-button="" mattooltip="Bonne réponse" aria-label="Bonne réponse" class="mdc-icon-button mat-mdc-icon-button mat-mdc-button-base mat-mdc-tooltip-trigger icon-button mat-unthemed" mat-ripple-loader-unin